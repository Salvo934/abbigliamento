# Firebase - copia in .env e compila con i valori dalla console Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Opzionale - per Analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Stripe - pagamenti
# Publishable key (frontend, opzionale se usi Stripe.js/Elementi)
VITE_STRIPE_PUBLISHABLE_KEY=
# Secret key (solo lato server, in Vercel: Settings → Environment Variables)
STRIPE_SECRET_KEY=
