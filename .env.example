# Firebase - copia in .env e compila con i valori dalla console Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Opzionale - per Analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Stripe - pagamenti (solo per "Carta di credito" al checkout)
# In locale con npm run dev:api; su Vercel: Settings → Environment Variables
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
